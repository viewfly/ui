{
  "name": "@viewfly/ui-icons",
  "version": "0.0.17",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./icons.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@viewfly/core": "^3.0.2",
    "@viewfly/platform-browser": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@viewfly/core": "^3.0.2",
    "@viewfly/platform-browser": "^3.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2"
  }
}
